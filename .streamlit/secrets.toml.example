# Vorlage für Streamlit-Secrets.
# LOKAL: zu ".streamlit/secrets.toml" kopieren (wird NICHT eingecheckt).
# AUF STREAMLIT CLOUD: Inhalt 1:1 unter "Settings -> Secrets" einfügen.

ODDS_API_KEY = "dein_odds_api_key_hier"
API_TENNIS_KEY = "dein_api_tennis_key_hier"

# Gemeinsames Passwort, das deine Freunde zum Öffnen brauchen:
APP_PASSWORD = "waehle_ein_passwort"

# Dauerhafte Datenbank (Cloud). Leer lassen = lokale SQLite-Datei.
# Beispiel Supabase (Connection-String aus dem Supabase-Dashboard kopieren):
# DATABASE_URL = "postgresql://postgres:DEIN_PASSWORT@db.xxxxx.supabase.co:5432/postgres"
DATABASE_URL = ""
