# Kopiere diese Datei zu ".env" und trage deine API-Keys ein.
# Die .env-Datei wird NICHT eingecheckt (siehe .gitignore).

# The Odds API – https://the-odds-api.com
ODDS_API_KEY=dein_odds_api_key_hier

# API-Tennis – https://api-tennis.com
API_TENNIS_KEY=dein_api_tennis_key_hier

# Gemeinsames Login-Passwort (leer lassen = kein Login)
APP_PASSWORD=waehle_ein_passwort

# Dauerhafte Datenbank (leer = lokale SQLite-Datei).
# Für die Cloud: Postgres-URL von Supabase eintragen, z. B.:
# DATABASE_URL=postgresql://postgres:PASSWORT@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=
